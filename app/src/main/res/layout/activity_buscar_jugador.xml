<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_panini">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Buscar Jugador"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:textStyle="bold"
            android:background="#66000000"
            android:padding="10dp"
            android:shadowColor="#000000"
            android:shadowDx="3"
            android:shadowDy="3"
            android:shadowRadius="4"
            android:layout_marginBottom="20dp"/>

        <EditText
            android:id="@+id/etNombreJugador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ej: Cristiano Ronaldo"
            android:textColor="#FFFFFF"
            android:textColorHint="#DDDDDD"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="15dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBuscar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Buscar jugador"
            android:textColor="#000000"
            app:backgroundTint="#FFFFFF"
            app:strokeColor="#000000"
            app:strokeWidth="3dp"/>

        <ImageView
            android:id="@+id/imgJugador"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:layout_gravity="center"
            android:layout_marginTop="25dp"
            android:layout_marginBottom="20dp"
            android:adjustViewBounds="true"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#CCFFFFFF"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre:"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="20sp"
                android:padding="6dp"/>

            <TextView
                android:id="@+id/tvEquipo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Equipo:"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="20sp"
                android:padding="6dp"/>

            <TextView
                android:id="@+id/tvNacionalidad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nacionalidad:"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="20sp"
                android:padding="6dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>